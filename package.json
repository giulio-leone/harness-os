{
  "name": "agent-harness-core",
  "version": "0.1.0",
  "description": "Reusable long-running agent harness core for Copilot-style runtimes.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "init": "bash scripts/init.sh",
    "mem0:mcp": "node dist/bin/mem0-mcp.js",
    "mem0:mcp:hot": "node dist/bin/mem0-mcp-hot-reload.js",
    "mem0:mcp:dev": "tsx src/bin/mem0-mcp.ts",
    "scheduler:daemon": "node dist/bin/scheduler-daemon.js",
    "session:lifecycle": "node dist/bin/session-lifecycle.js",
    "session:lifecycle:dev": "tsx src/bin/session-lifecycle.ts",
    "session:lifecycle:mcp": "node dist/bin/session-lifecycle-mcp.js",
    "session:lifecycle:mcp:dev": "tsx src/bin/session-lifecycle-mcp.ts"
  },
  "keywords": [
    "agent",
    "harness",
    "copilot",
    "mem0",
    "sqlite",
    "zod"
  ],
  "author": "",
  "license": "MIT",
  "private": true,
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
