      "scope": {
        "sources": ["ticket queues", "chat escalations", "email handoffs"],
        "qualityBar": "Every resolution path must include customer-safe wording and escalation criteria.",
        "sourceContext": ["CONTEXT.MD", "JOBS.MD", "NETWORK.MD"]
      }
    },
    {
      "id": "mission-support-resolution",
      "name": "support-resolution",
